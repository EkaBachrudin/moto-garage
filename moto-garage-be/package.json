{
  "name": "moto-garage-be",
  "version": "1.0.0",
  "description": "Backend API for Moto Garage application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/utils/migrate.ts",
    "migrate:up": "ts-node src/utils/migrate.ts up",
    "migrate:down": "ts-node src/utils/migrate.ts down",
    "migrate:status": "ts-node src/utils/migrate.ts status",
